# ── FREE options (no credit card required) ──────────────────────────────────

# OpenRouter — access free open-source LLMs (Llama, Gemma, Mistral, …)
# Get a free key at: https://openrouter.ai/keys
# Free models have a ":free" suffix — see https://openrouter.ai/models?q=free
OPENROUTER_API_KEY=sk-or-v14e6e95d35c33ed58ef6e669b122b0

# Gemini — generous free tier for script generation
# Get a free key at: https://aistudio.google.com/app/apikey
# Either name works: GEMINI_API_KEY or GOOGLE_API_KEY
GEMINI_API_KEY= AIzaSyD_5AAMEiyM7M7w

# Optional: override the default model (meta-llama/llama-3.3-70b-instruct:free)
# OPENROUTER_MODEL=google/gemma-3-27b-it:free
# OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free
# OPENROUTER_MODEL=qwen/qwen2.5-72b-instruct:free

# Hugging Face — free inference API for TTS and open-source chat models
# Get a free key at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hfkylURUbioQsPxVzK

# Optional: override the default chat model used for script generation
# HUGGINGFACE_MODEL=Qwen/Qwen2.5-72B-Instruct

# Optional: override the default TTS model (facebook/mms-tts-eng)
# Better quality but slower: espnet/kan-bayashi_ljspeech_vits
# HF_TTS_MODEL=facebook/mms-tts-eng

# ── PAID fallbacks (used only if the free keys above are not set) ────────────

# Groq — fast free-tier LLM (Llama 3.3 70B), second fallback for script
# GROQ_API_KEY=gsk_...

# Anthropic (Claude) — paid fallback for script generation
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — paid fallback for script generation + TTS
# OPENAI_API_KEY=sk-...

# ElevenLabs — high-quality TTS, 10k chars/month free tier
# ELEVENLABS_API_KEY=...
# ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL   # defaults to Rachel

# Note: copy this file to .env.local and fill in your keys.
# Never commit .env.local to git.
